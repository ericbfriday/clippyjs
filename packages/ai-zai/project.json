{
  "name": "@clippyjs/ai-zai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ai-zai/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:ai",
    "platform:node"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/ai-zai build"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": [
        "{workspaceRoot}/coverage/packages/ai-zai"
      ],
      "options": {
        "config": "packages/ai-zai/vitest.config.ts",
        "passWithNoTests": false,
        "reportsDirectory": "../../coverage/packages/ai-zai"
      }
    },
    "typecheck": {
      "executor": "@nx/js:tsc",
      "outputs": [],
      "options": {
        "tsConfig": "packages/ai-zai/tsconfig.json",
        "noEmit": true
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf packages/ai-zai/dist"
      }
    }
  }
}
