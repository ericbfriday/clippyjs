{
  "name": "@clippyjs/ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ai/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:ai",
    "platform:node"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/ai build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/packages/ai"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/ai vitest run"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "yarn workspace @clippyjs/ai typecheck"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf packages/ai/dist"
      }
    }
  }
}
