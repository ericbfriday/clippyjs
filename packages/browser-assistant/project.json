{
  "name": "@clippyjs/browser-assistant",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/browser-assistant/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:browser-assistant",
    "platform:browser"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/browser-assistant build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/packages/browser-assistant"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/browser-assistant vitest run"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/browser-assistant/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf packages/browser-assistant/dist"
      }
    }
  }
}
