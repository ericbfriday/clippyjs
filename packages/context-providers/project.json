{
  "name": "@clippyjs/context-providers",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/context-providers/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:context-providers",
    "platform:browser"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/context-providers build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/packages/context-providers"
      ],
      "options": {
        "command": "yarn workspace @clippyjs/context-providers vitest run"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/context-providers/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf packages/context-providers/dist"
      }
    }
  }
}
